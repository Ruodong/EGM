{
  "_comment": "Cross-feature dependency graph. Used by Claude for impact assessment before implementing new features.",
  "version": 1,
  "features": {
    "governance-requests": {
      "doc": "docs/features/governance-requests.md",
      "tables": ["governance_request", "governance_request_rule", "governance_request_attachment", "audit_log"],
      "routers": ["governance_requests.py", "employees.py"],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/requests/",
        "frontend/src/app/governance/"
      ]
    },
    "intake-scoping": {
      "doc": "docs/features/intake-scoping.md",
      "tables": ["intake_template", "intake_response", "intake_change_log"],
      "routers": ["intake.py"],
      "frontendPaths": [
        "frontend/src/app/governance/[requestId]/scoping/",
        "frontend/src/app/governance/[requestId]/common-questionnaire/"
      ]
    },
    "domain-dispatch": {
      "doc": "docs/features/domain-dispatch.md",
      "tables": [
        "domain_registry", "dispatch_rule", "dispatch_rule_domain", "domain_review",
        "domain_questionnaire_response", "domain_questionnaire_template",
        "info_supplement_request", "review_action", "review_comment"
      ],
      "routers": [
        "dispatcher.py", "dispatch_rules.py", "domain_registry.py",
        "domain_reviews.py", "info_requests.py"
      ],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/settings/",
        "frontend/src/app/(sidebar)/domains/",
        "frontend/src/app/(sidebar)/reviews/",
        "frontend/src/app/governance/[requestId]/reviews/"
      ]
    },
    "project-linking": {
      "doc": "docs/features/project-linking.md",
      "tables": ["project"],
      "routers": ["projects.py"],
      "frontendPaths": [
        "frontend/src/app/governance/create/"
      ]
    },
    "auth": {
      "doc": "docs/features/auth.md",
      "tables": ["user_role", "employee_info"],
      "routers": ["auth.py"],
      "frontendPaths": [
        "frontend/src/lib/auth-context.tsx",
        "frontend/src/components/layout/Header.tsx"
      ]
    },
    "dashboard": {
      "doc": "docs/features/dashboard.md",
      "tables": [],
      "routers": ["dashboard.py"],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/reports/"
      ]
    },
    "progress": {
      "doc": "docs/features/progress.md",
      "tables": [],
      "routers": ["progress.py"],
      "frontendPaths": []
    },
    "audit-log": {
      "doc": "docs/features/audit-log.md",
      "tables": ["audit_log"],
      "routers": ["audit_log.py"],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/settings/audit-log/"
      ]
    },
    "user-authorization": {
      "doc": "docs/features/user-authorization.md",
      "tables": ["user_role", "employee_info"],
      "routers": ["user_authorization.py"],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/settings/user-authorization/"
      ]
    },
    "questionnaire-templates": {
      "doc": "docs/features/questionnaire-templates.md",
      "tables": ["domain_questionnaire_template"],
      "routers": ["questionnaire_templates.py"],
      "frontendPaths": [
        "frontend/src/app/(sidebar)/settings/questionnaire-templates/"
      ]
    },
    "request-questionnaire": {
      "doc": "docs/features/request-questionnaire.md",
      "tables": ["request_questionnaire_response"],
      "routers": ["request_questionnaire.py"],
      "frontendPaths": [
        "frontend/src/app/governance/_components/DomainQuestionnaires.tsx",
        "frontend/src/app/governance/[requestId]/",
        "frontend/src/app/governance/create/"
      ]
    },
    "antd-migration": {
      "doc": "docs/features/antd-migration.md",
      "tables": [],
      "routers": [],
      "frontendPaths": [
        "frontend/src/app/providers.tsx",
        "frontend/src/components/layout/",
        "frontend/src/components/shared/",
        "frontend/src/components/ui/",
        "frontend/src/lib/constants.ts",
        "frontend/src/lib/domain-icons.ts",
        "frontend/src/styles/globals.css"
      ]
    }
  },
  "edges": [
    {
      "from": "intake-scoping",
      "to": "governance-requests",
      "type": "FK+status_write",
      "detail": "intake_response.request_id FK; evaluate endpoint sets governance_request.status = 'Scoping'"
    },
    {
      "from": "domain-dispatch",
      "to": "governance-requests",
      "type": "FK+status_write",
      "detail": "domain_review.request_id FK ON DELETE CASCADE; dispatcher sets status='In Review'; ISR sets 'Info Requested'; ISR resolve restores 'In Review'"
    },
    {
      "from": "domain-dispatch",
      "to": "intake-scoping",
      "type": "data_read",
      "detail": "dispatcher reads intake_response + intake_template.triggers_domain for scoping auto-evaluation"
    },
    {
      "from": "domain-dispatch",
      "to": "intake-scoping",
      "type": "data_write",
      "detail": "ISR change_reason links to intake_change_log entries"
    },
    {
      "from": "governance-requests",
      "to": "domain-dispatch",
      "type": "guard",
      "detail": "verdict endpoint checks all domain_review statuses are Complete/Waived + no open ISRs"
    },
    {
      "from": "project-linking",
      "to": "governance-requests",
      "type": "FK",
      "detail": "governance_request.project_id -> project.project_id ON DELETE SET NULL"
    },
    {
      "from": "governance-requests",
      "to": "domain-dispatch",
      "type": "FK",
      "detail": "governance_request_rule.rule_code FK -> dispatch_rule.rule_code; create/update request saves rule associations"
    },
    {
      "from": "questionnaire-templates",
      "to": "domain-dispatch",
      "type": "data_read",
      "detail": "questionnaire_templates reads domain_registry to filter internal domains; domain_questionnaire_template table shared"
    },
    {
      "from": "request-questionnaire",
      "to": "governance-requests",
      "type": "FK+guard",
      "detail": "request_questionnaire_response.request_id FK; submit endpoint validates all required questionnaire answers present"
    },
    {
      "from": "request-questionnaire",
      "to": "questionnaire-templates",
      "type": "data_read",
      "detail": "reads domain_questionnaire_template to determine which questions apply for triggered internal domains"
    },
    {
      "from": "request-questionnaire",
      "to": "domain-dispatch",
      "type": "data_read",
      "detail": "reads domain_registry to identify triggered internal domains for the request"
    }
  ],
  "sharedTables": {
    "governance_request": ["governance-requests", "intake-scoping", "domain-dispatch", "project-linking", "request-questionnaire"],
    "audit_log": ["governance-requests", "domain-dispatch", "audit-log"]
  },
  "globalFiles": [
    "backend/app/database.py",
    "backend/app/auth/",
    "frontend/src/lib/api.ts",
    "frontend/src/app/layout.tsx"
  ]
}
